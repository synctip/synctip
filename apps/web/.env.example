# Copy to .env.local. The .env.local file is gitignored.

# Optional: Sentry DSN for error tracking. Leave empty to disable Sentry.
VITE_SENTRY_DSN=

# Absolute origin of the API. The web app always talks to the API
# cross-origin — there is no dev proxy. Pick the value that matches
# how you are running the web app:
#
#   Plain localhost:        http://localhost:3000
#   Cloudflare Tunnel dev:  https://api-dev.synctip.com
#   Stage:                  https://api-stage.synctip.com
#   Beta:                   https://api-beta.synctip.com
#   Production:             https://api.synctip.com
VITE_API_URL=http://localhost:3000

# Optional override for the Better-Auth handler URL. If unset, this is
# automatically derived as `${VITE_API_URL}/auth`, which is correct in
# every standard environment. Only set this if your auth handler lives
# at a different host or path than the rest of the API.
# VITE_AUTH_BASE_URL=http://localhost:3000/auth
