# Copy to .env.local. The .env.local file is gitignored.

# Optional: Sentry DSN for error tracking. Leave empty to disable Sentry.
VITE_SENTRY_DSN=

# Optional: Absolute URL of the Better-Auth handler. Only needed when the
# web and API are served from different origins. Defaults to
# `<current origin>/api/auth` (which works in dev via the Vite proxy).
# Example: https://api.synctip.com/auth
VITE_AUTH_BASE_URL=
