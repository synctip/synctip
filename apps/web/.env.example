# Copy to .env.local. The .env.local file is gitignored.

# Optional: Sentry DSN for error tracking. Leave empty to disable Sentry.
VITE_SENTRY_DSN=

# Absolute URL of the Better-Auth handler. Only needed when the web and
# API are served from different origins (e.g. prod where api lives on
# its own subdomain). Defaults to `<current origin>/auth` which works in
# dev via the Vite proxy.
# Example: https://api.synctip.com/auth
VITE_AUTH_BASE_URL=

# Absolute origin of the API. Required for cross-origin deploys; in dev
# leave empty so requests stay relative and hit the Vite proxy.
# Example: https://api.synctip.com
VITE_API_URL=
