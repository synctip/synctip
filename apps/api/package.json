  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch run src/main.ts",
    "start:debug": "bun --inspect --watch run src/main.ts",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "bun test src",
    "test:watch": "bun test src --watch",
    "test:cov": "bun test src --coverage",
    "test:debug": "bun test src --inspect-brk",
    "test:e2e": "bun test test"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@sentry/node": "^10.62.0",
    "@synctip/api-client": "workspace:*",
    "@synctip/db": "workspace:*",
    "better-auth": "^1.6.22",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
