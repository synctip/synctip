# Copy to .env. The .env file is gitignored.

# Connection string for the local Postgres started by `docker compose up -d`.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in the repo root .env.
DATABASE_URL="postgresql://synctip:change-me-locally@localhost:5432/synctip_dev"

# HTTP port the Nest server binds to.
PORT=3000

# Deployment tier this instance represents. One of:
#   production | beta | stage | develop
# Surfaced in the /health response so probes and the web UI can confirm
# which environment they are actually talking to. See docs/DEPLOYMENT.md.
APP_ENV=develop

# Comma-separated list of origins allowed to call the API via CORS.
# The web app always talks to the API cross-origin (no dev proxy), so
# every web origin you serve must be listed here. Include both your
# plain-localhost and tunnel front-ends in dev.
# Example: WEB_ORIGIN=https://synctip.com,https://www.synctip.com
WEB_ORIGIN=http://localhost:5173,https://dev.synctip.com

# Optional: Sentry DSN for error tracking. Leave empty to disable Sentry.
SENTRY_DSN=

# === Better-Auth ===========================================================
# Generate a strong secret with: bunx better-auth secret
AUTH_SECRET=

# Absolute URL of the Better-Auth handler. Better-Auth derives its route
# prefix from this URL's pathname, so the `/auth` suffix is required.
#
# This value must be the URL the BROWSER uses to talk to auth (used to
# build OAuth redirect URIs). Always points at the API origin.
#
# Local dev:                     http://localhost:3000/auth
# Cloudflare Tunnel dev:         https://api-dev.synctip.com/auth
# Stage (api on subdomain):      https://api-stage.synctip.com/auth
# Beta (api on subdomain):       https://api-beta.synctip.com/auth
# Production (api on subdomain): https://api.synctip.com/auth
AUTH_BASE_URL=http://localhost:3000/auth

# === Google OAuth ==========================================================
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_BASE_URL}/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Twilio Verify (SMS-OTP) ===============================================
# Verify generates AND validates the OTP; no `from` phone number needed.
# Account SID + Auth Token: https://console.twilio.com (Account Info)
# Verify Service SID (VA...): https://console.twilio.com/us1/develop/verify/services
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
