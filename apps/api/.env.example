# Copy to .env. The .env file is gitignored.

# Connection string for the local Postgres started by `docker compose up -d`.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in the repo root .env.
DATABASE_URL="postgresql://synctip:change-me-locally@localhost:5432/synctip_dev"

# HTTP port the Nest server binds to.
PORT=3000

# Comma-separated list of origins allowed to call the API via CORS.
# In dev the Vite proxy handles this, so this is mainly for prod.
# Example: WEB_ORIGIN=https://synctip.com,https://www.synctip.com
WEB_ORIGIN=http://localhost:5173

# Optional: Sentry DSN for error tracking. Leave empty to disable Sentry.
SENTRY_DSN=
